# Editor / OS noise
*.swp
*.swo
*~
.DS_Store

# Claude Code: deny-by-default — track only config, never secrets/runtime state
# (Global instructions are shared, not per-tool: see shared/agent-instructions.md,
# which init.sh links to ~/.claude/CLAUDE.md and each agent's AGENTS.md.)
claude/*
!claude/settings.json
!claude/commands/
!claude/commands/**
!claude/agents/
!claude/agents/**

# Codex: deny-by-default — track only config, never secrets/runtime state
codex/*
!codex/dotfiles.config.toml
!codex/prompts/
!codex/prompts/**
!codex/rules/
!codex/rules/no-push.rules

# Agy: deny-by-default — track only config, never secrets/runtime state
gemini/antigravity-cli/*
!gemini/antigravity-cli/settings.json
!gemini/antigravity-cli/skills/
!gemini/antigravity-cli/skills/**

# Temporary Files
tmp/
