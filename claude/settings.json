{
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git -* push)",
      "Bash(git -* push *)"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "auto",
  "editorMode": "normal"
}
