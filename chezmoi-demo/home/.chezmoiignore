# .chezmoiignore — target paths chezmoi should NOT manage in $HOME.
# This file is itself a template: the conditionals are evaluated per machine at
# apply time, so one source tree produces the right set of files everywhere
# (the job init.sh did by only symlinking certain files per OS).

# The WezTerm desktop launcher is Linux-only (init_linux.sh installs it today).
{{ if ne .chezmoi.os "linux" }}
.config/wezterm/org.wezfurlong.wezterm.desktop
{{ end }}

