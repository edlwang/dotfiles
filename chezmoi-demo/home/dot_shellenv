# ~/.shellenv — managed by chezmoi (plain file → symlinked in symlink mode).
#
# Why this file survives the move to chezmoi: its two helpers act on RUNTIME
# state that apply-time templating can't precompute —
#   * path_prepend inspects the live $PATH and whether a dir exists right now;
#   * winpath transforms a path value ($HOME as the running shell sees it), via a
#     cygpath capability probe.
# The uname-based SYSTEM_OS dispatch, by contrast, is an APPLY-TIME fact: chezmoi
# resolves it in the templates (dot_bashrc.tmpl) and the run_ scripts, so nothing
# in the rendered config consults SYSTEM_OS at runtime. It's kept below only as an
# optional convenience for future runtime branching — you can delete it.
case "$(uname -s)" in
    Linux*)                 export SYSTEM_OS="Linux";;
    Darwin*)                export SYSTEM_OS="macOS";;
    CYGWIN*|MINGW*|MSYS*)   export SYSTEM_OS="Windows";;
    *)                      export SYSTEM_OS="Unknown";;
esac

# Convert an MSYS path (/c/...) to Windows-mixed form (C:/...); no-op off Windows.
winpath() {
    if command -v cygpath >/dev/null 2>&1; then
        cygpath -m "$1"
    else
        printf '%s' "$1"
    fi
}

# Move a directory to the FRONT of PATH (dropping any earlier occurrence) when
# it exists; a no-op for a missing dir.
path_prepend() {
    [ -d "$1" ] || return
    local p=":${PATH}:"
    p="${p//:$1:/:}"        # drop any existing occurrence
    p="${p#:}"; p="${p%:}"  # trim the framing colons
    export PATH="$1${p:+:$p}"
}
