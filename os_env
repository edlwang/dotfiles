# Shared shell bootstrap, sourced by both bashrc (at shell startup) and init.sh
# (at install time) so they always agree. Sets SYSTEM_OS and defines helpers;
# keep it side-effect-free apart from that.
case "$(uname -s)" in
    Linux*)                 export SYSTEM_OS="Linux";;
    Darwin*)                export SYSTEM_OS="macOS";;
    CYGWIN*|MINGW*|MSYS*)   export SYSTEM_OS="Windows";;
    *)                      export SYSTEM_OS="Unknown";;
esac

# Convert an MSYS path (/c/...) to Windows-mixed form (C:/...) so native Windows
# tools can resolve it; a no-op where cygpath doesn't exist (i.e. on Unix).
winpath() {
    if command -v cygpath >/dev/null 2>&1; then
        cygpath -m "$1"
    else
        printf '%s' "$1"
    fi
}

# Move a directory to the FRONT of PATH (dropping any earlier occurrence) when
# it exists; a no-op for a missing dir. Shared so both callers agree: bashrc
# asserts its PATH priorities with it at shell startup, and init.sh uses it to
# surface a freshly-installed tool mid-run. Drop-then-prepend keeps re-sourcing
# idempotent and lets the last call win.
path_prepend() {
    [ -d "$1" ] || return
    local p=":${PATH}:"
    p="${p//:$1:/:}"        # drop any existing occurrence
    p="${p#:}"; p="${p%:}"  # trim the framing colons
    export PATH="$1${p:+:$p}"
}
