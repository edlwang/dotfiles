# User-level WezTerm launcher that shadows the distro entry in
# /usr/share/applications/. It launches the GUI via `connect unix` so windows
# attach to the persistent mux server. The system entry hardcodes
# `Exec=wezterm start --cwd .`; that explicit `start` overrides our
# default_gui_startup_args = {"connect","unix"} (which only applies with no
# subcommand), so the distro entry opens non-persistent local-domain windows.
# Installed by init.sh's setup_os (init_linux.sh). See AGENTS.md / wezterm.lua.
[Desktop Entry]
Name=WezTerm
Comment=Wez's Terminal Emulator
Keywords=shell;prompt;command;commandline;cmd;
Icon=org.wezfurlong.wezterm
StartupWMClass=org.wezfurlong.wezterm
TryExec=wezterm-gui
Exec=wezterm-gui connect unix
Type=Application
Categories=System;TerminalEmulator;Utility;
Terminal=false
