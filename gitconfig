[user]
	name = Edward Wang
	email = work@edlwang.com
[alias]
	sminit = submodule update --init --recursive
	smpull = submodule update --remote --recursive
	smfetch = fetch --recurse-submodules
	st = status -sb
	co = checkout
	sw = switch
	br = branch
	ci = commit
	di = diff
	lg = log --oneline --graph --all
	last = log -1 HEAD --stat
	cob = checkout -b
	swc = switch -c
	cane = commit --amend --no-edit
	unstage = reset HEAD --
	undo = reset --soft HEAD~1
[init]
	defaultBranch = main
[url "git@github.com:"]
	pushInsteadOf = https://github.com/
	pushInsteadOf = https://www.github.com/
[url "git@gitlab.com:"]
	pushInsteadOf = https://gitlab.com/
	pushInsteadOf = https://www.gitlab.com/
; Per-machine overrides (identity, etc.) — untracked, optional. Must come
; last so it wins over the default [user] above when present.
[include]
	path = ~/.gitconfig.local
[pull]
	ff = only
[merge]
	ff = false
